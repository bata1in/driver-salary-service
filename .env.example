# Local-first defaults.
DATABASE_URL=sqlite:///./data/app.db
APP_HOST=127.0.0.1
APP_PORT=8000

# Optional HTTP basic auth for server mode. Leave empty for local trusted use.
APP_USERNAME=
APP_PASSWORD=

# 1C OData connection. Entity and field names can differ between 1C configs,
# so keep them configurable instead of hard-coding Russian metadata names.
ODATA_BASE_URL=
ODATA_USERNAME=
ODATA_PASSWORD=
ODATA_VERIFY_TLS=true
ODATA_ROUTE_SHEET_ENTITY=Document_МаршрутныйЛист
ODATA_DELIVERY_REQUEST_ENTITY=Document_ЗаявкаНаДоставку
ODATA_EMPLOYEE_ENTITY=Catalog_Сотрудники
ODATA_COUNTERPARTY_ENTITY=Catalog_Контрагенты
ODATA_ROUTE_REQUESTS_FIELD=Заявки
ODATA_DELIVERY_REQUEST_KEY_FIELDS=Заявка_Key,DeliveryRequest_Key

ODATA_REF_KEY_FIELDS=Ref_Key,RefKey
ODATA_ROUTE_NUMBER_FIELDS=Number,Номер
ODATA_ROUTE_DATE_FIELDS=ДатаДоставки,DeliveryDate,Date,Дата
ODATA_ROUTE_WEIGHT_FIELDS=Вес,Weight,WeightKg
ODATA_DRIVER_FIELDS=Курьер_Key,Водитель_Key,Driver_Key,Сотрудник_Key,Driver
ODATA_EMPLOYEE_NAME_FIELDS=Description,Наименование,Name
ODATA_COUNTERPARTY_FIELDS=Контрагент,Контрагент_Key,Counterparty,Customer
ODATA_COUNTERPARTY_NAME_FIELDS=НаименованиеПолное,FullName,Description,Наименование,Name
ODATA_ADDRESS_FIELDS=АдресДоставки,Адрес,Address,DeliveryAddress
ODATA_PICKUP_FIELDS=АвтоматическийЗаборСоСклада,ЭтоЗабор,Забор,IsPickup
ODATA_DELIVERED_AT_FIELDS=ДатаВремяАвтоматическогоПосещения
